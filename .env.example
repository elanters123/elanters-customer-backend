PORT=3050
NODE_ENV=development

# MongoDB — same cluster as customer-app-backend
MONGO_URI=

# JWT secrets — isolated per app
CUSTOMER_JWT_SECRET=
CUSTOMER_JWT_REFRESH_SECRET=

# Secret token for client validation
SECRET_TOKEN_KEY=

# SMS — Fast2SMS
FAST_SMS_API=

# Razorpay
RAZ_ID=
RAZ_SECRET=

# CORS origins (comma-separated for multiple)
WEB_CLIENT_URL=http://localhost:3000
MOBILE_CLIENT_URL=*
